{
  "name": "serverless/ts-lambda-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:bundle": "ts-node src/build-bundle.ts",
    "build:handler": "esbuild src/handler.ts --bundle --platform=node --target=node22 --outfile=dist/handler.js --external:./workflow-bundle.js --external:@swc/core --external:@swc/wasm --external:'*.node'",
    "build": "pnpm run build:bundle && pnpm run build:handler",
    "client": "ts-node src/client.ts"
  },
  "dependencies": {
    "@temporalio/activity": "^1.16.0",
    "@temporalio/client": "^1.16.0",
    "@temporalio/envconfig": "^1.16.0",
    "@temporalio/lambda-worker": "^1.16.0",
    "@temporalio/worker": "^1.16.0",
    "@temporalio/workflow": "^1.16.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^22.0.0",
    "@tsconfig/node22": "^22.0.0",
    "esbuild": "^0.24.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
