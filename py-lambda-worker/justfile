# Install dependencies
install:
    uv sync

# No bundle step needed for Python (no V8 isolate sandbox)
build:
    @echo "No build step required for Python workers"

# SAM build (runs Makefile target, populates .aws-sam/build/)
sam-build:
    sam build

# Deploy to AWS. Omit build_id to auto-increment minor version (v1.1 → v1.2);
# pass an explicit version to use that instead: just deploy v2.0
deploy build_id="":
    ./scripts/deploy.sh {{ build_id }}

# Invoke the Lambda locally against a running Temporal dev server
# SAM local runs inside Docker — host.docker.internal routes to your machine
invoke:
    sam local invoke WorkerFunction \
        --event events/invoke.json \
        --env-vars events/local-env.json

# Tail CloudWatch logs after a real deployment
logs stack="aspinks-py-lambda-worker":
    sam logs --name WorkerFunction --stack-name {{ stack }} --tail \
        --profile SolutionsArchitecture/AWSAdministratorAccess \
        --region us-east-2

# Run a local worker against a Temporal dev server (for local development)
run-worker:
    uv run python -m app.worker

# Start a workflow against a local Temporal dev server (for testing)
start-workflow:
    uv run python -m app.client

# Print the `temporal worker deployment create-version` command for the deployed stack.
# Run this after `just deploy` to register the new Lambda version with Temporal Cloud.
register-version stack="aspinks-py-lambda-worker":
    #!/usr/bin/env bash
    set -euo pipefail
    query_output() {
      aws cloudformation describe-stacks \
        --stack-name {{ stack }} \
        --profile SolutionsArchitecture/AWSAdministratorAccess \
        --region us-east-2 \
        --query "Stacks[0].Outputs[?OutputKey=='$1'].OutputValue" \
        --output text
    }
    query_param() {
      aws cloudformation describe-stacks \
        --stack-name {{ stack }} \
        --profile SolutionsArchitecture/AWSAdministratorAccess \
        --region us-east-2 \
        --query "Stacks[0].Parameters[?ParameterKey=='$1'].ParameterValue" \
        --output text
    }
    FUNCTION_VERSION_ARN=$(query_output WorkerFunctionVersionArn)
    ROLE_ARN=$(query_output TemporalCloudInvokeRoleArn)
    BUILD_ID=$(query_output BuildId)
    DEPLOY_NAME=$(query_param TemporalDeploymentName)
    EXTERNAL_ID=$(query_param AssumeRoleExternalId)
    echo ""
    echo "Run this to register the deployed version with Temporal Cloud:"
    echo ""
    echo "temporal worker deployment create-version \\"
    echo "  --deployment-name $DEPLOY_NAME \\"
    echo "  --build-id $BUILD_ID \\"
    echo "  --aws-lambda-function-arn $FUNCTION_VERSION_ARN \\"
    echo "  --aws-lambda-assume-role-arn $ROLE_ARN \\"
    echo "  --aws-lambda-assume-role-external-id $EXTERNAL_ID"
    echo ""
